@startuml
skinparam monochrome false
left to right direction

    package "SafeRoute" {
        package "Trip" {
            package "Domain" {
                package "Model" {
                    class "TripError" as TripError {
                        +Id: Guid
                        +CreatedAt: DateTime
                        +Validate(): bool
                        +ToString(): string
                    }

                    package "Aggregates" {
                        class "Trip" as Trip {
                            +Id: TripId
                            +OrganizationId: OrganizationId
                            +RouteId: RouteId
                            +DriverId: DriverId
                            +State: TripState
                            +StartTime: DateTimeOffset?
                            +EndTime: DateTimeOffset?
                            -_attendances: List<Attendance>
                            -_incidents: List<Incident>
                            +Attendances: IReadOnlyCollection<Attendance>
                            +Incidents: IReadOnlyCollection<Incident>
                            +Start(): void
                            +Complete(): void
                            +SetBoardingStatus(ChildId childId, BoardingState state): void
                            +ReportIncident(IncidentDescription description): void
                            +GetAttendanceSummary(): IReadOnlyCollection<Attendance>
                            +GetIncidentLog(): IReadOnlyCollection<Incident>
                            +IsInProgress(): bool
                        }

                    }
                    package "Commands" {
                        class "CompleteTripCommand" as CompleteTripCommand <<Command>> {
                            +TripId: Guid
                            +CreatedAt: DateTime
                            +Validate(): bool
                            +ToString(): string
                        }

                        class "CreateTripCommand" as CreateTripCommand <<Command>> {
                            +OrganizationId: Guid
                            +RouteId: Guid
                            +Validate(): bool
                            +ToString(): string
                        }

                        class "StartTripCommand" as StartTripCommand <<Command>> {
                            +TripId: Guid
                            +CreatedAt: DateTime
                            +Validate(): bool
                            +ToString(): string
                        }

                        class "SetBoardingStatusCommand" as SetBoardingStatusCommand <<Command>> {
                            +TripId: Guid
                            +ChildId: Guid
                            +Validate(): bool
                            +ToString(): string
                        }

                        class "ReportIncidentCommand" as ReportIncidentCommand <<Command>> {
                            +TripId: Guid
                            +Description: string
                            +Validate(): bool
                            +ToString(): string
                        }

                    }
                    package "Events" {
                        class "TripCompletedEvent" as TripCompletedEvent <<Event>> {
                            +TripId: Guid
                            +CompletedAt: DateTimeOffset
                            +Validate(): bool
                            +ToString(): string
                        }

                        class "TripStartedEvent" as TripStartedEvent <<Event>> {
                            +TripId: Guid
                            +StartedAt: DateTimeOffset
                            +Validate(): bool
                            +ToString(): string
                        }

                    }
                    package "Queries" {
                        class "GetAllTripsQuery" as GetAllTripsQuery <<Query>> {
                            +Id: Guid
                            +CreatedAt: DateTime
                            +Validate(): bool
                            +ToString(): string
                        }

                        class "GetTripByIdQuery" as GetTripByIdQuery <<Query>> {
                            +TripId: Guid
                            +CreatedAt: DateTime
                            +Validate(): bool
                            +ToString(): string
                        }

                        class "GetTripsByRouteIdQuery" as GetTripsByRouteIdQuery <<Query>> {
                            +RouteId: Guid
                            +CreatedAt: DateTime
                            +Validate(): bool
                            +ToString(): string
                        }

                    }
                    package "ValueObjects" {
                        class "TripState" as TripState {
                            +Value: string
                            +CreatePending(): TripState
                            +IsPending(): bool
                            +IsInProgress(): bool
                            +IsCompleted(): bool
                            +ToString(): string
                        }

                        class "BoardingState" as BoardingState {
                            +Value: string
                            +IsBoarded(): bool
                            +IsMissing(): bool
                            +IsOmitted(): bool
                            +ToString(): string
                        }

                        class "IncidentDescription" as IncidentDescription {
                            +Value: string
                            +ToString(): string
                        }

                        class "AttendanceId" as AttendanceId {
                            +Identifier: Guid
                            +New(): AttendanceId
                            +ToString(): string
                        }

                        class "IncidentId" as IncidentId {
                            +Identifier: Guid
                            +New(): IncidentId
                            +ToString(): string
                        }

                    }
                    package "Entities" {
                        class "Attendance" as Attendance {
                            +Id: AttendanceId
                            +ChildId: ChildId
                            +BoardingState: BoardingState
                            +BoardedAt: DateTimeOffset?
                            +UpdateBoardingState(BoardingState state): void
                            +IsBoarded(): bool
                            +GetBoardingTime(): DateTimeOffset?
                        }

                        class "Incident" as Incident {
                            +Id: IncidentId
                            +Description: IncidentDescription
                            +ReportedAt: DateTimeOffset
                            +GetDescription(): string
                            +GetReportedAt(): DateTimeOffset
                        }

                    }
                }
                package "Repositories" {
                    interface "ITripRepository" as ITripRepository <<Repository>> {
                        +Validate(): bool
                        +ToString(): string
                    }

                }
            }
            package "Application" {
                package "CommandServices" {
                    interface "ITripCommandService" as ITripCommandService <<ApplicationService>> {
                        +Validate(): bool
                        +ToString(): string
                    }

                }
                package "QueryServices" {
                    interface "ITripQueryService" as ITripQueryService <<ApplicationService>> {
                        +Validate(): bool
                        +ToString(): string
                    }

                }
                package "Internal" {
                    class "TripCommandService" as TripCommandService <<ApplicationService>> {
                        +TripRepository: ITripRepository
                        +UnitOfWork: IUnitOfWork
                        +Handle(CreateTripCommand command, CancellationToken cancellationToken): Task<Result<TripAggregate>>
                        +Handle(StartTripCommand command, CancellationToken cancellationToken): Task<Result<TripAggregate>>
                    }

                    package "QueryServices" {
                        class "TripQueryService" as TripQueryService <<ApplicationService>> {
                            +TripRepository: ITripRepository
                            +CreatedAt: DateTime
                            +Handle(GetTripByIdQuery query, CancellationToken cancellationToken): Task<TripAggregate?>
                            +Handle(GetAllTripsQuery query, CancellationToken cancellationToken): Task<IEnumerable<TripAggregate>>
                        }

                    }
                }
            }
        }
    }

package "Shared" as Shared { }

' ─── Relationships ───
Attendance ..> BoardingState : uses
Attendance ..> Shared : uses ChildId
Attendance *-- AttendanceId : contains
Attendance *-- BoardingState : contains
Attendance *-- Shared : contains ChildId
Incident ..> IncidentDescription : uses
Incident *-- IncidentDescription : contains
Incident *-- IncidentId : contains
ITripRepository ..|> Shared : implements IBaseRepository
Trip ..> Attendance : uses
Trip ..> BoardingState : uses
Trip ..> CreateTripCommand : uses
Trip ..> Incident : uses
Trip ..> IncidentDescription : uses
Trip ..> Shared : uses ChildId
Trip ..> Shared : uses DriverId
Trip ..> Shared : uses OrganizationId
Trip ..> Shared : uses RouteId
Trip *-- Attendance : contains
Trip *-- Incident : contains
Trip *-- Shared : contains DriverId
Trip *-- Shared : contains OrganizationId
Trip *-- Shared : contains RouteId
Trip *-- Shared : contains TripId
Trip *-- TripState : contains
TripCommandService ..> "Action<TripAggregate>" : uses
TripCommandService ..> CancellationToken : uses
TripCommandService ..> CompleteTripCommand : handles
TripCommandService ..> CreateTripCommand : handles
TripCommandService ..> ReportIncidentCommand : handles
TripCommandService ..> SetBoardingStatusCommand : handles
TripCommandService ..> StartTripCommand : handles
TripCommandService ..> TripAggregate : uses
TripCommandService *-- "IStringLocalizer<ErrorMessages>" : contains
TripCommandService *-- ITripRepository : contains
TripCommandService *-- Shared : contains IUnitOfWork
TripQueryService ..> CancellationToken : uses
TripQueryService ..> GetAllTripsQuery : handles
TripQueryService ..> GetTripByIdQuery : handles
TripQueryService ..> GetTripsByRouteIdQuery : handles
TripQueryService ..> TripAggregate : uses
TripQueryService *-- ITripRepository : contains
@enduml
